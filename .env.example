# Gmail OAuth
GMAIL_CREDENTIALS_FILE=credentials.json
GMAIL_TOKEN_FILE=token.json
GMAIL_USER_ID=me

# LLM
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=YOUR_KEY
LLM_MODEL=gpt-4.1-mini
ENABLE_LLM=true
LLM_REDACT=true

# Cleanup
CLEANUP_MODE=archive
ENABLE_UNSUBSCRIBE=true
DRY_RUN=true
SAFE_MODE=true
JUNK_CONFIDENCE_THRESHOLD=0.8
IMPORTANT_CONFIDENCE_THRESHOLD=0.75
JUNK_REPEAT_THRESHOLD=5
REQUIRE_RULE_FOR_JUNK=true

# Scheduling
SCAN_WINDOW_MINUTES=60
SCAN_INTERVAL_MINUTES=10
MAX_RESULTS_PER_SCAN=100

# Notifications
NOTIFY_TELEGRAM=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
NOTIFY_EMAIL_SUMMARY=false
NOTIFY_WEBHOOK=false
WEBHOOK_URL=

# API auth users stored in configs/users.json
# Accounts stored in configs/accounts.json

# Unsubscribe safety
UNSUBSCRIBE_ALLOWLIST=
BLOCK_PRIVATE_IPS=true

# Access control lists (comma-separated)
ALLOWED_SENDERS=
BLOCKED_SENDERS=
PROTECTED_DOMAINS=

# Paths
DATABASE_PATH=data/email_assistant.db
LOG_PATH=logs/app.log
